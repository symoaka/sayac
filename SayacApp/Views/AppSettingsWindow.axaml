<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:SayacApp.Services"
        x:Class="SayacApp.Views.AppSettingsWindow"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/soonish.ico"
        Title="{Binding [SettingsLong], Source={x:Static svc:LocalizationService.Instance}}">

    <StackPanel Margin="18" Spacing="14">
        <TextBlock Classes="h1"
                   Text="{Binding [SettingsLong], Source={x:Static svc:LocalizationService.Instance}}" />

        <!-- Custom shortcuts -->
        <Border Classes="section">
            <StackPanel Spacing="10">
                <TextBlock Classes="h2"
                           Text="{Binding [CustomShortcuts], Source={x:Static svc:LocalizationService.Instance}}" />
                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="value" VerticalAlignment="Center"
                               Text="{Binding [ToggleMini], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" MinWidth="120" Margin="10,0,10,0"
                               Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding MiniHotkeyText}" />
                    <Button Grid.Row="0" Grid.Column="2" Classes="secondary" Command="{Binding ListenMiniCommand}"
                            Content="{Binding [Listen], Source={x:Static svc:LocalizationService.Instance}}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="value" VerticalAlignment="Center" Margin="0,10,0,0"
                               Text="{Binding [ToggleMain], Source={x:Static svc:LocalizationService.Instance}}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" MinWidth="120" Margin="10,10,10,0"
                               Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding MainHotkeyText}" />
                    <Button Grid.Row="1" Grid.Column="2" Classes="secondary" Command="{Binding ListenMainCommand}" Margin="0,10,0,0"
                            Content="{Binding [Listen], Source={x:Static svc:LocalizationService.Instance}}" />
                </Grid>
                <TextBlock Classes="label" TextWrapping="Wrap" Text="{Binding Status}" />
            </StackPanel>
        </Border>

        <!-- Mini controls -->
        <Border Classes="section">
            <StackPanel Spacing="10">
                <TextBlock Classes="h2"
                           Text="{Binding [MiniControls], Source={x:Static svc:LocalizationService.Instance}}" />
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <CheckBox Grid.Row="0" Grid.Column="0" IsChecked="{Binding Settings.MiniLocked}"
                              Content="{Binding [MiniLocked], Source={x:Static svc:LocalizationService.Instance}}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="value" VerticalAlignment="Center" Margin="0,10,0,0"
                               Text="{Binding [Show], Source={x:Static svc:LocalizationService.Instance}}" />
                    <ComboBox Grid.Row="1" Grid.Column="1" Width="120" Margin="0,10,0,0" SelectedIndex="{Binding DisplayIndex}">
                        <ComboBoxItem>1</ComboBoxItem>
                        <ComboBoxItem>3</ComboBoxItem>
                        <ComboBoxItem>5</ComboBoxItem>
                        <ComboBoxItem Content="{Binding [All], Source={x:Static svc:LocalizationService.Instance}}" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="value" VerticalAlignment="Center" Margin="0,10,0,0"
                               Text="{Binding [MiniOpacity], Source={x:Static svc:LocalizationService.Instance}}" />
                    <Slider Grid.Row="2" Grid.Column="1" Width="180" Minimum="0" Maximum="255" Margin="0,10,0,0"
                            Value="{Binding Settings.MiniOpacity}" />
                </Grid>
                <Button Classes="secondary" HorizontalAlignment="Left" Command="{Binding RecoverMiniCommand}"
                        Content="{Binding [RecoverMini], Source={x:Static svc:LocalizationService.Instance}}" />
            </StackPanel>
        </Border>

        <!-- Appearance: theme + language -->
        <Border Classes="section">
            <StackPanel Spacing="10">
                <TextBlock Classes="h2"
                           Text="{Binding [Appearance], Source={x:Static svc:LocalizationService.Instance}}" />
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="value" VerticalAlignment="Center"
                               Text="{Binding [Theme], Source={x:Static svc:LocalizationService.Instance}}" />
                    <ComboBox Grid.Row="0" Grid.Column="1" Width="140" SelectedIndex="{Binding ThemeIndex}">
                        <ComboBoxItem Content="{Binding [ThemeSystem], Source={x:Static svc:LocalizationService.Instance}}" />
                        <ComboBoxItem Content="{Binding [ThemeLight], Source={x:Static svc:LocalizationService.Instance}}" />
                        <ComboBoxItem Content="{Binding [ThemeDark], Source={x:Static svc:LocalizationService.Instance}}" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="value" VerticalAlignment="Center" Margin="0,10,0,0"
                               Text="{Binding [CounterStyle], Source={x:Static svc:LocalizationService.Instance}}" />
                    <ComboBox Grid.Row="1" Grid.Column="1" Width="140" Margin="0,10,0,0" SelectedIndex="{Binding CounterStyleIndex}">
                        <ComboBoxItem Content="{Binding [StyleAnimated], Source={x:Static svc:LocalizationService.Instance}}" />
                        <ComboBoxItem Content="{Binding [StyleMinimal], Source={x:Static svc:LocalizationService.Instance}}" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="value" VerticalAlignment="Center" Margin="0,10,0,0"
                               Text="{Binding [Language], Source={x:Static svc:LocalizationService.Instance}}" />
                    <ComboBox Grid.Row="2" Grid.Column="1" Width="140" Margin="0,10,0,0" SelectedIndex="{Binding LanguageIndex}">
                        <ComboBoxItem>Türkçe</ComboBoxItem>
                        <ComboBoxItem>English</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <Button HorizontalAlignment="Right" Classes="secondary" Click="OnClose"
                Content="{Binding [Close], Source={x:Static svc:LocalizationService.Instance}}" />
    </StackPanel>
</Window>
