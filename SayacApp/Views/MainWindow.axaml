<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:SayacApp.Services"
        xmlns:conv="using:SayacApp.Converters"
        x:Class="SayacApp.Views.MainWindow"
        x:Name="Root"
        Width="720" Height="600"
        MinWidth="380" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/soonish.ico"
        Title="{Binding [AppTitle], Source={x:Static svc:LocalizationService.Instance}}">

    <Window.Resources>
        <conv:StringNotEmptyConverter x:Key="NotEmpty" />
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="20,18,20,12" Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Image Source="/Assets/soonish.png" Width="28" Height="28" VerticalAlignment="Center" />
                    <TextBlock Classes="h1" VerticalAlignment="Center"
                               Text="{Binding [AppTitle], Source={x:Static svc:LocalizationService.Instance}}" />
                </StackPanel>
                <Button Grid.Column="1" Classes="secondary" VerticalAlignment="Center"
                        Command="{Binding OpenSettingsCommand}"
                        Content="{Binding [SettingsLong], Source={x:Static svc:LocalizationService.Instance}}" />
            </Grid>

            <Border Classes="accentbar" />

            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding NewName}" MinWidth="120" Margin="0,0,8,0"
                         Watermark="{Binding [ColName], Source={x:Static svc:LocalizationService.Instance}}" />
                <Button Grid.Column="1" Classes="secondary" Margin="0,0,8,0" MinWidth="170"
                        Content="{Binding NewWhenSummary}">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Spacing="12" Width="300" Margin="4">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="📅" FontSize="14" />
                                        <TextBlock Classes="h2"
                                                   Text="{Binding [DateLabel], Source={x:Static svc:LocalizationService.Instance}}" />
                                    </StackPanel>
                                    <CalendarDatePicker SelectedDate="{Binding NewCalendarDate}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🕐" FontSize="14" />
                                        <TextBlock Classes="h2"
                                                   Text="{Binding [TimeLabel], Source={x:Static svc:LocalizationService.Instance}}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <NumericUpDown Width="110" Minimum="0" Maximum="23" Increment="1"
                                                       FormatString="00" Value="{Binding NewHour}" />
                                        <TextBlock Classes="h2" Text=":" VerticalAlignment="Center" />
                                        <NumericUpDown Width="110" Minimum="0" Maximum="59" Increment="1"
                                                       FormatString="00" Value="{Binding NewMinute}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Grid.Column="2" Classes="accent" Command="{Binding AddCommand}"
                        Content="{Binding [Add], Source={x:Static svc:LocalizationService.Instance}}" />
            </Grid>
        </StackPanel>

        <ScrollViewer>
            <Panel Margin="20,4,20,18">
                <Border Classes="section" IsVisible="{Binding !HasCounters}" Padding="20,44" Margin="0,30,0,0">
                    <TextBlock Classes="label" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Text="{Binding [NoCounters], Source={x:Static svc:LocalizationService.Instance}}" />
                </Border>

                <ItemsControl ItemsSource="{Binding Counters}" IsVisible="{Binding HasCounters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="tile" Width="324" Margin="0,0,12,12" Padding="0">
                                <Panel>
                                    <Border Classes="tilefill" Background="{Binding GlowBrush}"
                                            RenderTransform="{Binding GlowTransform}"
                                            IsVisible="{Binding !$parent[ItemsControl].DataContext.Settings.MinimalTiles}" />
                                    <Border Classes="tileglow"
                                            BorderBrush="{Binding GlowBorderBrush}"
                                            BoxShadow="{Binding GlowShadow}"
                                            IsVisible="{Binding !$parent[ItemsControl].DataContext.Settings.MinimalTiles}" />
                                <Grid Margin="16" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                    <!-- color chip: emoji, or name initial as fallback -->
                                    <Border Grid.Row="0" Grid.Column="0" Classes="chip" Width="44" Height="44"
                                            VerticalAlignment="Top" Background="{Binding BackgroundBrush}">
                                        <Panel>
                                            <TextBlock Classes="chiptext" Text="{Binding InitialChar}"
                                                       IsVisible="{Binding Icon, Converter={StaticResource NotEmpty}, ConverterParameter=invert}" />
                                            <TextBlock Classes="chiptext" Text="{Binding Icon}"
                                                       IsVisible="{Binding Icon, Converter={StaticResource NotEmpty}}" />
                                        </Panel>
                                    </Border>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Classes="h2" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Classes="label" Text="{Binding TargetText}" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Button Classes="subtle" Padding="8,5"
                                                Command="{Binding $parent[ItemsControl].DataContext.EditCounterCommand}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding [Settings], Source={x:Static svc:LocalizationService.Instance}}" />
                                        <Button Classes="subtle danger" Padding="8,5"
                                                Command="{Binding $parent[ItemsControl].DataContext.DeleteCounterCommand}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding [Delete], Source={x:Static svc:LocalizationService.Instance}}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,16,0,0">
                                        <TextBlock Classes="count" Text="{Binding RemainingBig}"
                                                   IsVisible="{Binding RemainingBig, Converter={StaticResource NotEmpty}}" />
                                        <TextBlock Classes="countclock" Text="{Binding RemainingClock}"
                                                   IsVisible="{Binding RemainingClock, Converter={StaticResource NotEmpty}}" />
                                    </StackPanel>
                                </Grid>
                                </Panel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Panel>
        </ScrollViewer>
    </DockPanel>
</Window>
