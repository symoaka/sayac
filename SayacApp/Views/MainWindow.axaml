<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="using:SayacApp.Services"
        x:Class="SayacApp.Views.MainWindow"
        x:Name="Root"
        Width="620" Height="580"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding [AppTitle], Source={x:Static svc:LocalizationService.Instance}}">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8" Spacing="10">
            <TextBlock Classes="h1"
                       Text="{Binding [AppTitle], Source={x:Static svc:LocalizationService.Instance}}" />

            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding NewName}" Margin="0,0,8,0"
                         Watermark="{Binding [ColName], Source={x:Static svc:LocalizationService.Instance}}" />
                <DatePicker Grid.Column="1" SelectedDate="{Binding NewDate}" Margin="0,0,8,0" />
                <TimePicker Grid.Column="2" SelectedTime="{Binding NewTime}" ClockIdentifier="24HourClock" Margin="0,0,8,0" />
                <Button Grid.Column="3" Command="{Binding AddCommand}" Margin="0,0,8,0"
                        Content="{Binding [Add], Source={x:Static svc:LocalizationService.Instance}}" />
                <Button Grid.Column="4" Command="{Binding OpenSettingsCommand}"
                        Content="{Binding [SettingsLong], Source={x:Static svc:LocalizationService.Instance}}" />
            </Grid>

            <Border Height="1" Background="#2A2A2A" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer>
            <Panel Margin="16,8,16,16">
                <TextBlock Classes="label" HorizontalAlignment="Center" Margin="0,40,0,0"
                           TextWrapping="Wrap" TextAlignment="Center"
                           IsVisible="{Binding !HasCounters}"
                           Text="{Binding [NoCounters], Source={x:Static svc:LocalizationService.Instance}}" />

                <ItemsControl ItemsSource="{Binding Counters}" IsVisible="{Binding HasCounters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="15" FontWeight="Bold"
                                               Foreground="#FFFFFF" Text="{Binding Name}" />
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                        <TextBlock Classes="label"
                                                   Text="{Binding [Target], Source={x:Static svc:LocalizationService.Instance}}" />
                                        <TextBlock Classes="label" Text=":" />
                                        <TextBlock Classes="label" Text="{Binding TargetText}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                               VerticalAlignment="Center" Margin="12,0" MinWidth="120"
                                               TextAlignment="Right" FontSize="18" FontWeight="Bold"
                                               Foreground="#FFFFFF" Text="{Binding RemainingText}" />

                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0"
                                            Command="{Binding $parent[ItemsControl].DataContext.EditCounterCommand}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding [Settings], Source={x:Static svc:LocalizationService.Instance}}" />
                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].DataContext.DeleteCounterCommand}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding [Delete], Source={x:Static svc:LocalizationService.Instance}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Panel>
        </ScrollViewer>
    </DockPanel>
</Window>
