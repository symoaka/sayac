<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Window / typography ============ -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.value">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <!-- Counter "time remaining" readout: accent normally, muted once completed. -->
    <Style Selector="TextBlock.remaining">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBlock.remaining.completed">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- ============ Surfaces ============ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.section">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
    </Style>

    <!-- ============ Playful counter tiles ============ -->
    <Style Selector="Border.tile">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <!-- Static colored edge + soft halo behind the tile (cached; not animated). -->
    <Style Selector="Border.tileglow">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <!-- Progress fill: grows from the right edge as a GPU scaleX the transition eases
         (smooth, no per-frame layout or blur). Background brush is bound per counter. -->
    <Style Selector="Border.tilefill">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="1,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                                               Duration="0:0:1" Easing="LinearEasing" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Color chip holding the counter's emoji / initial -->
    <Style Selector="Border.chip">
        <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="TextBlock.chiptext">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Big countdown number + monospaced clock -->
    <Style Selector="TextBlock.count">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.countclock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, monospace" />
    </Style>

    <!-- Thin gradient accent strip (ties the UI to the logo) -->
    <Style Selector="Border.accentbar">
        <Setter Property="Height" Value="3" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}" />
    </Style>

    <!-- ============ Inputs (light touch: rounded; accent comes from SystemAccentColor) ============ -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- ============ Accent (primary) button ============ -->
    <Style Selector="Button.accent">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>

    <!-- ============ Secondary button ============ -->
    <Style Selector="Button.secondary">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- ============ Subtle / icon button (edit/delete) ============ -->
    <Style Selector="Button.subtle">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Button.subtle /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="Button.subtle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.subtle:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.subtle.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>

</Styles>
